{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ErrorResponse",
  "description": "Standard HTTP API error response shape for client-facing transports (Skill 07 - error-handling)",
  "type": "object",
  "required": ["timestamp", "status", "error", "message"],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp of when the error occurred",
      "example": "2025-06-15T10:30:00.000Z"
    },
    "status": {
      "type": "integer",
      "description": "HTTP status code or the equivalent client-facing status",
      "enum": [400, 401, 403, 404, 409, 422, 500, 503],
      "example": 404
    },
    "error": {
      "type": "string",
      "description": "Short, client-safe error label",
      "examples": ["Not Found", "Bad Request", "Forbidden", "Conflict", "Internal Server Error"]
    },
    "message": {
      "type": "string",
      "description": "Human-readable, client-safe error message. Never include stack traces or internal details.",
      "example": "Resource not found"
    },
    "path": {
      "type": "string",
      "description": "Optional request path for HTTP transports",
      "example": "/api/resources/99"
    },
    "requestId": {
      "type": "string",
      "description": "Optional correlation or request identifier for incident tracking",
      "example": "req_01HZXQ7Q7BX9GJ6V2T0W8NZ7YQ"
    },
    "details": {
      "description": "Optional machine-readable validation or dependency details when the contract allows them"
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "timestamp": "2025-06-15T10:30:00.000Z",
      "status": 404,
      "error": "Not Found",
      "message": "Resource not found",
      "path": "/api/resources/99",
      "requestId": "req_01HZXQ7Q7BX9GJ6V2T0W8NZ7YQ"
    },
    {
      "timestamp": "2025-06-15T10:31:00.000Z",
      "status": 400,
      "error": "Bad Request",
      "message": "Validation failed",
      "details": {
        "name": ["must not be blank"],
        "price": ["must be greater than 0"]
      }
    },
    {
      "timestamp": "2025-06-15T10:32:00.000Z",
      "status": 500,
      "error": "Internal Server Error",
      "message": "An unexpected error occurred"
    }
  ]
}
