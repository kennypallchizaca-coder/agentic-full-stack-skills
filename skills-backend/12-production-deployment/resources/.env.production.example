# .env.production.example — Production Environment Variables

# ─── Server ────────────────────────────────────────────────
PORT=8080
APP_ENV=production          # Must be "production" in production

# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@your-db-host:5432/your-db-name
# DB_POOL_SIZE=10           # Optional: connection pool max size

# ─── Application Security ─────────────────────────────────
APP_SECRET=replace-with-a-long-random-value-never-commit-this
# TOKEN_SIGNING_KEY=        # Optional: only if the app signs JWTs or cookies
# TOKEN_TTL_SECONDS=86400   # Optional: token or session TTL

# ─── Application ───────────────────────────────────────────
# LOG_LEVEL=info            # debug | info | warn | error
# SENTRY_DSN=               # Error monitoring (optional)

# ─── Stack-Specific Optional Knobs ─────────────────────────
# ORM_SCHEMA_MODE=validate  # Example: keep schema changes out of runtime start
# ORM_LOG_SQL=false         # Example: keep SQL logging disabled in production
