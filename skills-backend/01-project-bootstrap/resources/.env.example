# .env.example — Project Bootstrap

# Required base runtime settings
PORT=8080
APP_ENV=development

# Optional HTTP / platform settings
# HOST=0.0.0.0
# CORS_ORIGIN=http://localhost:3000
# REQUEST_TIMEOUT_MS=10000

# Optional persistence settings
# DATABASE_URL=postgresql://user:password@localhost:5432/app
# REDIS_URL=redis://localhost:6379
# MONGO_URL=mongodb://localhost:27017/app

# Optional auth settings
# JWT_SECRET=replace-with-a-random-string-of-at-least-32-characters
# JWT_EXPIRATION_SECONDS=86400
# SESSION_SECRET=replace-with-a-random-string

# Optional observability
# LOG_LEVEL=info
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
